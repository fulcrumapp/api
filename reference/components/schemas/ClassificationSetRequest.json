{
  "type": "object",
  "properties": {
    "classification_set": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the classification set"
        },
        "description": {
          "type": "string",
          "description": "Description of the classification set"
        },
        "items": {
          "type": "array",
          "description": "Classification items with hierarchical structure",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string",
                "description": "Display label"
              },
              "value": {
                "type": "string",
                "description": "Value stored"
              },
              "child_classifications": {
                "type": "array",
                "description": "Child classification items",
                "items": {
                  "type": "object"
                }
              }
            },
            "required": ["label", "value"]
          }
        }
      },
      "required": ["name", "items"]
    }
  },
  "required": ["classification_set"]
}
